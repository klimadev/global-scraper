{
  "manifest_version": 3,
  "name": "Global Scraper",
  "version": "0.2.0",
  "description": "Extrai anúncios de múltiplos marketplaces (OLX, Mercado Livre e mais) com interface adaptativa",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "*://*.olx.com.br/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Global Scraper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["core/*.js", "platforms/*.js"],
    "matches": ["<all_urls>"]
  }]
}
